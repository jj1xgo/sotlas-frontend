{
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/x/issues",
      "headers": {
        "Authorization": "Bearer ${GITHUB_MCP_PAT}"
      }
    },
    "playwright": {
      "command": "node",
      "env": {
        "XDG_CONFIG_HOME": "/home/node/.cache/xdg-config"
      },
      "args": [
        ".claude-container.d/playwright-mcp/node_modules/@playwright/mcp/cli.js",
        "--browser", "chromium",
        "--executable-path", "/usr/bin/chromium",
        "--headless",
        "--no-sandbox",
        "--isolated",
        "--viewport-size", "1280x800",
        "--caps", "vision",
        "--output-dir", ".claude/playwright-mcp"
      ]
    }
  }
}
